# Veritabanı — docker-compose.yml ile eşleşmeli
POSTGRES_USER=ornek_user
POSTGRES_PASSWORD=ornek_password
POSTGRES_DB=ornek_db
DATABASE_URL=postgresql+asyncpg://ornek_user:ornek_password@db:5432/ornek_db

# JWT ayarları — SECRET_KEY hariç değiştirmenize gerek yok
SECRET_KEY=change-this-to-a-random-256-bit-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Uygulama ayarları
APP_ENV=development
CORS_ORIGINS=http://localhost:3000

STORAGE_BACKEND=minio          # "minio" veya "s3"
STORAGE_BUCKET=otm-files

# MinIO (local)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin    (lokal ortam için -> kendiniz belirleyebilirsiniz)
MINIO_SECRET_KEY=minioadmin    (lokal ortam için -> kendiniz belirleyebilirsiniz)
MINIO_SECURE=false             # local'de HTTP

# S3 (prod)            (production aşamasında eklenecek)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=eu-central-1