# Veritabanı — docker-compose.yml ile eşleşmeli
POSTGRES_USER=ornek_user
POSTGRES_PASSWORD=ornek_password
POSTGRES_DB=ornek_db
DATABASE_URL=postgresql+asyncpg://ornek_user:ornek_password@db:5432/ornek_db

# JWT ayarları — SECRET_KEY hariç değiştirmenize gerek yok
SECRET_KEY=change-this-to-a-random-256-bit-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Uygulama ayarları
APP_ENV=development
CORS_ORIGINS=http://localhost:3000